# =============================================================================
# Rust + Next.js Template Environment Configuration
# =============================================================================
# Copy this file to .env.local and update with your actual values:
#     cp .env.example .env.local
# =============================================================================

# -----------------------------------------------------------------------------
# Application Mode
# -----------------------------------------------------------------------------
# full:     Rust server (port 3000) proxies to Next.js (port 3001). Single entry point.
# api-only: Rust API server standalone. Next.js runs separately with rewrites.
APP_MODE=full

# -----------------------------------------------------------------------------
# Rust Server Configuration
# -----------------------------------------------------------------------------
# SERVER_PORT: Port where Rust server listens (default: 3000)
SERVER_PORT=3000

# HOST: Bind address for both Rust and Next.js servers (default: 127.0.0.1)
# For remote access (e.g., Codespaces, containers): set to 0.0.0.0
HOST=127.0.0.1

# SERVER_PROXY_URL: URL to proxy non-/api requests to the frontend (full mode only)
# Default: http://127.0.0.1:${PORT}
# SERVER_PROXY_URL=http://127.0.0.1:3001

# -----------------------------------------------------------------------------
# Next.js / Frontend Configuration
# -----------------------------------------------------------------------------
# PORT: Port where Next.js server listens (default: 3001 in full mode, 3000 in api-only)
PORT=3001


# -----------------------------------------------------------------------------
# GitHub Pages (Static Export)
# -----------------------------------------------------------------------------
# Set GITHUB_PAGES=true for static export mode (no server required)
# GITHUB_PAGES=true
# NEXT_PUBLIC_BASE_PATH=/your-repo-name

# -----------------------------------------------------------------------------
# Public Variables (Exposed to Browser)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_API_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
# RATE_LIMIT_PER_SECOND: Token replenish rate (default: 2)
# RATE_LIMIT_PER_SECOND=2

# RATE_LIMIT_BURST: Max burst of requests before limiting (default: 10)
# RATE_LIMIT_BURST=10

# -----------------------------------------------------------------------------
# Swagger UI
# -----------------------------------------------------------------------------
# Set SWAGGER_UI=false to disable Swagger UI (enabled by default)
# SWAGGER_UI=false

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# RUST_LOG=info
