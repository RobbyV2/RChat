# =============================================================================
# RChat Environment Configuration
# =============================================================================
# Copy this file to .env.local and update with your actual values:
#     cp .env.local.example .env.local
# =============================================================================

# -----------------------------------------------------------------------------
# Application Mode
# -----------------------------------------------------------------------------
# full:     Rust server (port 3000) proxies to Next.js (port 3001). Single entry point.
# api-only: Rust API server standalone. Next.js runs separately with rewrites.
APP_MODE=full

# -----------------------------------------------------------------------------
# Rust Server Configuration
# -----------------------------------------------------------------------------
# SERVER_PORT: Port where Rust server listens (default: 3000)
SERVER_PORT=3000

# HOST: Bind address for both Rust and Next.js servers (default: 127.0.0.1)
# For remote access (e.g., Codespaces, containers): set to 0.0.0.0
HOST=127.0.0.1

# SERVER_PROXY_URL: URL to proxy non-/api requests to the frontend (full mode only)
# Default: http://127.0.0.1:${PORT}
# SERVER_PROXY_URL=http://127.0.0.1:3001

# -----------------------------------------------------------------------------
# Next.js / Frontend Configuration
# -----------------------------------------------------------------------------
# PORT: Port where Next.js server listens (default: 3001 in full mode, 3000 in api-only)
PORT=3001

# NEXT_PUBLIC_API_URL: API base for api-only mode rewrites (default: http://HOST:SERVER_PORT)
# NEXT_PUBLIC_API_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# DATABASE_URL: sqlite file holding everything (users, messages, media blobs)
# DATABASE_URL=rchat.db

# -----------------------------------------------------------------------------
# S3 Media Storage (optional)
# -----------------------------------------------------------------------------
# When all four required vars are set, uploaded media blobs go to the
# S3-compatible bucket at key media/{id} instead of the database (path-style
# addressing, so minio works). Unset = blobs stay in the database.
# S3_ENDPOINT=http://127.0.0.1:9000
# S3_BUCKET=rchat
# S3_ACCESS_KEY=...
# S3_SECRET_KEY=...
# S3_REGION=us-east-1

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
# RATE_LIMIT_PER_SECOND: Token replenish rate per IP (default: 10)
# RATE_LIMIT_PER_SECOND=10

# RATE_LIMIT_BURST: Max burst of requests before limiting (default: 60)
# RATE_LIMIT_BURST=60

# -----------------------------------------------------------------------------
# Guests
# -----------------------------------------------------------------------------
# GUESTS_ENABLED: seeds the guests_enabled site setting on first startup only
# (default: true); afterwards the site admin panel toggle owns the value
# GUESTS_ENABLED=true

# -----------------------------------------------------------------------------
# Voice
# -----------------------------------------------------------------------------
# VOICE_IDLE_SECS: a voice room or call with one occupant for this long is ended
# VOICE_IDLE_SECS=60

# -----------------------------------------------------------------------------
# PeerJS (P2P calls and files)
# -----------------------------------------------------------------------------
# PEERJS_PORT: port for the local PeerServer spawned by just dev/prod (default: 9001)
# PEERJS_PORT=9001

# NEXT_PUBLIC_PEERJS_PORT: port the browser dials for PeerJS (default: 9001;
# host defaults to window.location.hostname)
# NEXT_PUBLIC_PEERJS_PORT=9001

# -----------------------------------------------------------------------------
# Swagger UI
# -----------------------------------------------------------------------------
# Set SWAGGER_UI=false to disable Swagger UI (enabled by default, login required)
# SWAGGER_UI=false

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# RUST_LOG=info
